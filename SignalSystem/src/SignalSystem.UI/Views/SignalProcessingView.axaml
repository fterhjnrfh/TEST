<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SignalSystem.UI.ViewModels"
             x:Class="SignalSystem.UI.Views.SignalProcessingView"
             x:DataType="vm:SignalProcessingViewModel">

    <ScrollViewer>
        <StackPanel Spacing="12" Margin="8">
            <!-- 标题 -->
            <TextBlock Text="⚙️ 信号处理" FontSize="20" FontWeight="Bold" />

            <!-- 输入监控 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="输入监控" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="状态：" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="吞吐：" Margin="16,0,8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding InputThroughput, StringFormat={}{0:F2} MB/s}" />
                        <TextBlock Grid.Column="4" Text="已接收：" Margin="16,0,8,0" />
                        <TextBlock Grid.Column="5" Text="{Binding ReceivedFrames, StringFormat={}{0} 帧}" />
                        <TextBlock Grid.Column="6" Text="⏱ 耗时：" Margin="16,0,8,0" />
                        <TextBlock Grid.Column="7" Text="{Binding ElapsedTime}" FontWeight="Bold" FontFamily="Consolas" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 预处理配置 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="预处理配置" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,160,Auto,120" RowDefinitions="Auto">
                        <TextBlock Grid.Column="0" Text="方法：" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailablePreprocessMethods}"
                                  SelectedItem="{Binding SelectedPreprocess}" />
                        <TextBlock Grid.Column="2" Text="LPC阶数：" VerticalAlignment="Center" Margin="16,0,8,0" />
                        <NumericUpDown Grid.Column="3"
                                       Value="{Binding LpcOrder}"
                                       Minimum="1" Maximum="32" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 压缩配置 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="压缩配置" FontWeight="SemiBold" />
                    <!-- 算法选择 -->
                    <Grid ColumnDefinitions="Auto,160" RowDefinitions="Auto">
                        <TextBlock Grid.Column="0" Text="算法：" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableAlgorithms}"
                                  SelectedItem="{Binding SelectedAlgorithm}" />
                    </Grid>
                    <!-- 等级配置 -->
                    <StackPanel Spacing="4" IsEnabled="{Binding LevelEnabled}">
                        <Grid ColumnDefinitions="Auto,100,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0" Text="压缩等级：" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding CompressionLevel}"
                                           Minimum="{Binding LevelMin}"
                                           Maximum="{Binding LevelMax}"
                                           IsEnabled="{Binding LevelEnabled}" />
                            <TextBlock Grid.Column="2" Text="{Binding LevelHint}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="12" Opacity="0.6" FontStyle="Italic" />
                        </Grid>
                    </StackPanel>
                    <!-- 窗口配置 -->
                    <StackPanel Spacing="4" IsEnabled="{Binding WindowEnabled}">
                        <Grid ColumnDefinitions="Auto,100,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0" Text="窗口大小：" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding WindowSize}"
                                           Minimum="0"
                                           IsEnabled="{Binding WindowEnabled}" />
                            <TextBlock Grid.Column="2" Text="{Binding WindowHint}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="12" Opacity="0.6" FontStyle="Italic" />
                        </Grid>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="启用无损校验" IsChecked="{Binding EnableVerification}" />
                        <TextBlock Text="{Binding VerificationStatus}" VerticalAlignment="Center"
                                   FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 组合配置 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="组合配置管理" FontWeight="SemiBold" />
                    <!-- 保存路径 -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,4">
                        <TextBlock Text="保存路径：" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding SaveFolderPath}" Watermark="选择数据保存目录..." />
                        <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowseSaveFolderCommand}" Margin="8,0,0,0" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="💾 保存 Profile" Command="{Binding SaveProfileCommand}" />
                        <Button Content="📂 加载 Profile" Command="{Binding LoadProfileCommand}" />
                        <Button Content="▶ 开始处理" Command="{Binding StartProcessingCommand}" />
                        <Button Content="⏹ 停止处理" Command="{Binding StopProcessingCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 输出监控 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="输出监控" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
                        <TextBlock Grid.Column="0" Text="压缩比：" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding CompressionRatio, StringFormat={}{0:F2}x}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="写入速度：" Margin="16,0,8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding WriteSpeedMBps, StringFormat={}{0:F2} MB/s}" />
                        <TextBlock Grid.Column="4" Text="已写入：" Margin="16,0,8,0" />
                        <TextBlock Grid.Column="5" Text="{Binding TotalBytesWritten, StringFormat={}{0:N0} bytes}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 处理日志 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="处理日志" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="清空" Command="{Binding ClearLogCommand}" />
                    </Grid>
                    <ListBox ItemsSource="{Binding ProcessingLog}" MinHeight="100" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
