<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SignalSystem.UI.ViewModels"
             x:Class="SignalSystem.UI.Views.SignalSourceView"
             x:DataType="vm:SignalSourceViewModel">

    <ScrollViewer>
        <StackPanel Spacing="12" Margin="8">
            <!-- 标题 -->
            <TextBlock Text="📡 信号数据源" FontSize="20" FontWeight="Bold" />

            <!-- SDK 状态面板 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="SDK 状态" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto" >
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="连接状态：" Margin="0,0,8,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SdkStatus}" FontWeight="Bold" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="帧率：" Margin="16,0,8,4" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding FrameRate, StringFormat={}{0:F1} fps}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="总帧数：" Margin="0,0,8,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalFrames}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="丢帧数：" Margin="16,0,8,0" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding DroppedFrames}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="初始化" Command="{Binding InitializeCommand}" />
                        <Button Content="启动" Command="{Binding StartCommand}" />
                        <Button Content="停止" Command="{Binding StopCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 设备管理 -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="设备管理" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Content="＋ 添加设备" Command="{Binding AddDeviceCommand}" />
                            <Button Content="－ 删除设备" Command="{Binding RemoveDeviceCommand}" />
                        </StackPanel>
                    </Grid>

                    <ListBox ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice}"
                             MinHeight="100" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:DeviceItemViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding DeviceId}" Width="80" />
                                    <TextBlock Text="{Binding DeviceName}" Width="120" />
                                    <TextBlock Text="{Binding Status}" Opacity="0.6" />
                                    <TextBlock Text="{Binding Channels.Count, StringFormat={}通道数: {0}}" Opacity="0.6" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- 通道配置（选中设备时显示） -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12"
                    IsVisible="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="通道配置" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Content="＋ 添加通道" Command="{Binding SelectedDevice.AddChannelCommand}" />
                            <Button Content="－ 删除通道" Command="{Binding SelectedDevice.RemoveChannelCommand}" />
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding SelectedDevice.Channels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ChannelItemViewModel">
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="4,8" Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="120,120,120,120,120" RowDefinitions="Auto,Auto">
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,4">
                                            <TextBlock Text="通道ID" FontSize="11" Opacity="0.5" />
                                            <TextBlock Text="{Binding ChannelId}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,4">
                                            <TextBlock Text="信号类型" FontSize="11" Opacity="0.5" />
                                            <ComboBox ItemsSource="{x:Static vm:SignalSourceViewModel.SignalTypes}"
                                                      SelectedItem="{Binding SignalType}"
                                                      MinWidth="100" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,4">
                                            <TextBlock Text="采样率(Hz)" FontSize="11" Opacity="0.5" />
                                            <NumericUpDown Value="{Binding SampleRate}" Minimum="1" Maximum="1000000" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,8,4">
                                            <TextBlock Text="幅值" FontSize="11" Opacity="0.5" />
                                            <NumericUpDown Value="{Binding Amplitude}" Minimum="0" Increment="0.1" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,8,4">
                                            <TextBlock Text="频率(Hz)" FontSize="11" Opacity="0.5" />
                                            <NumericUpDown Value="{Binding Frequency}" Minimum="0" Maximum="100000" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
