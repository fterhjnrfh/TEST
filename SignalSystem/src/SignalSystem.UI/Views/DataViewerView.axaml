<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SignalSystem.UI.ViewModels"
             xmlns:ctrl="using:SignalSystem.UI.Controls"
             x:Class="SignalSystem.UI.Views.DataViewerView"
             x:DataType="vm:DataViewerViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- 标题 + 打开文件 -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="8">
            <TextBlock Text="📊 数据查看" FontSize="20" FontWeight="Bold" />
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Content="📂 打开文件" Command="{Binding OpenFileCommand}" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="{Binding FilePath}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Opacity="0.7" />
                <TextBlock Grid.Column="2" Text="{Binding FileInfo}" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.5" />
            </Grid>
        </StackPanel>

        <!-- 设备 / 通道选择 -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4"
                Padding="12" Margin="8,0,8,8">
            <Grid ColumnDefinitions="300,*">
                <!-- 左：设备选择 -->
                <StackPanel Spacing="6">
                    <TextBlock Text="选择设备" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding DeviceList}"
                              SelectedItem="{Binding SelectedDevice}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>

                <!-- 右：通道多选 -->
                <StackPanel Grid.Column="1" Spacing="6" Margin="16,0,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Text="选择通道" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="全选" Command="{Binding SelectAllChannelsCommand}"
                                Padding="8,2" Margin="0,0,6,0" />
                        <Button Grid.Column="2" Content="取消全选" Command="{Binding DeselectAllChannelsCommand}"
                                Padding="8,2" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ChannelList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ChannelNode">
                                <Border Margin="0,2,12,2" Padding="4,2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                        <Border Width="12" Height="12" CornerRadius="2"
                                                Background="{Binding DisplayColor}" VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="{Binding ChannelId}" />
                                            <Run Text=" (" /><Run Text="{Binding SignalType}" /><Run Text=")" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding SampleCount, StringFormat={}{0} pts}"
                                                   FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 波形绘制区域 -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4"
                Margin="8,0,8,8" ClipToBounds="True">
            <Grid RowDefinitions="*,Auto">
                <ctrl:WaveformCanvas Waveforms="{Binding Waveforms}"
                                     DisplayStart="{Binding DisplayStart, Mode=TwoWay}"
                                     DisplayCount="{Binding DisplayCount, Mode=TwoWay}"
                                     MaxSamples="{Binding MaxSamples}"
                                     YMin="{Binding YMin}"
                                     YMax="{Binding YMax}"
                                     SampleRate="{Binding SampleRateValue}"
                                     Name="WaveformChart" />
                <!-- 图例 -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Legends}" Margin="8,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:LegendItem">
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
                                <Border Width="16" Height="3" Background="{Binding Color}"
                                        VerticalAlignment="Center" />
                                <TextBlock FontSize="12" VerticalAlignment="Center">
                                    <Run Text="{Binding ChannelId}" />
                                    <Run Text=" [" /><Run Text="{Binding SignalType}" /><Run Text="]" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
